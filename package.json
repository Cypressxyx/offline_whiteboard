{
  "name": "whiteboard",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "lint:html": "htmlhint index.html",
    "lint:js": "eslint whiteboard.js",
    "lint": "npm run lint:html && npm run lint:js",
    "format:check": "prettier --check \"*.{html,js}\" \"tests/**/*.js\"",
    "format": "prettier --write \"*.{html,js}\" \"tests/**/*.js\"",
    "test": "jest",
    "test:update": "jest --updateSnapshot",
    "validate": "npm run lint && npm run format:check && npm run test"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "htmlhint": "^1.1.4",
    "jest": "^29.7.0",
    "prettier": "^3.2.0"
  }
}
